Options +FollowSymLinks
RewriteEngine On
RewriteBase /mini-projet-articles/

# ── Ignorer les fichiers/dossiers réels ──────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ── Rediriger les routes vers un routeur central ──────────────────────
# Toutes les routes (sauf index.php) vont vers le routeur
RewriteRule ^(.+)$ router.php?_route=$1 [L,QSA]

# ── Erreurs ──────────────────────────────────────────────────────────
ErrorDocument 404 /mini-projet-articles/app/Views/front/404.php

# ── Sécurité ─────────────────────────────────────────────────────────
<FilesMatch "\.(env|sql|log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
Options -Indexes
AddDefaultCharset UTF-8

# ── Performances Lighthouse ───────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

