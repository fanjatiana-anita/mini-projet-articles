# Fichier .htaccess pour URL Rewriting - Iran News FrontOffice

# Activer le moteur de réécriture
Options +FollowSymLinks
RewriteEngine On

# Base du répertoire
RewriteBase /

# Réécriture page article
# URL: /article/mon-article-slug → article.php?slug=mon-article-slug
RewriteRule ^article/([a-z0-9\-]+)/?$ article.php?slug=$1 [L,QSA]

# Réécriture catégorie
# URL: /categorie/politique → categorie.php?slug=politique
RewriteRule ^categorie/([a-z0-9\-]+)/?$ categorie.php?slug=$1 [L,QSA]

# Rediriger les erreurs 404 vers la page d'accueil
ErrorDocument 404 /index.php

# Empêcher l'accès aux fichiers sensibles
<FilesMatch "\.(env|sql|log|htaccess)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Empêcher le listing des répertoires
Options -Indexes

# Forcer UTF-8
AddDefaultCharset UTF-8

# Cache pour les assets statiques (améliore les performances Lighthouse)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Compression GZIP (améliore les performances Lighthouse)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/xml
</IfModule>
